        // Daily usage from Firebase (approximation based on today's data)
        setDailyUsage({
          testUsed: todayPerf.testTotal > 0 ? 1 : 0,
          testLimit: 1,
          practiceUsed: todayPerf.practiceTotal > 0 ? Math.ceil(todayPerf.practiceTotal / 10) : 0,
